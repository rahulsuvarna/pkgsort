{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* Production builds ship only compiled library sources — no tests or config. */
    "rootDir": "src",
    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "coverage", "tests", "**/*.test.ts", "**/*.spec.ts"]
}
